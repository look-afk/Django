# Example environment variables for Django Postgres configuration
# Copy this to .env and fill values for local development / production

# DB_ENGINE: 'postgresql' (default) or 'sqlite'
DB_ENGINE=postgresql

# Postgres settings
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_HOST=localhost
DB_PORT=5432

# Optional: to use sqlite instead, set DB_ENGINE=sqlite and optionally SQLITE_NAME
#DB_ENGINE=sqlite
#SQLITE_NAME=db.sqlite3
